{
  "name": "instant-glue-dashboard",
  "version": "1.0.0",
  "description": "Clear dashboard for instant production-grade AI-powered webhooks.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
